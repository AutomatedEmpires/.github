{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":dependencyDashboard"],
  "timezone": "America/Los_Angeles",
  "schedule": ["before 9am on monday"],
  "labels": ["type:deps"],
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "lockFileMaintenance": { "enabled": true },
  "packageRules": [
    { "description": "Group non-major updates", "matchUpdateTypes": ["minor", "patch"], "groupName": "non-major" },
    { "description": "Pin runtime - require manual review for Node/pnpm bumps", "matchPackageNames": ["node", "pnpm"], "dependencyDashboardApproval": true },
    { "description": "Auto-merge safe dev-dependency patches", "matchDepTypes": ["devDependencies"], "matchUpdateTypes": ["patch"], "automerge": true }
  ]
}